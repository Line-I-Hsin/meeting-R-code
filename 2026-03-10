###給定連續時間找mean function
Smooth_function1=function(t,Y,n,h=0.3,t2=seq(0.2,0.8,length=200)){
  Y_smooth=matrix(0,nrow=n,ncol=length(t2))
  for(i in 1:n){
    Y_index=Y[i,]
    for(j in 1:length(t2)){
      t0=t2[j]
      z=(t-t0)/h
      k=ifelse((3/4)*(1-z^2)>=0,(3/4)*(1-z^2),0)
      W=diag(k)
      T1=cbind(1,(t-t0))
      beta_hat=solve(t(T1)%*%W%*%T1)%*%t(T1)%*%W%*%Y_index
      Y_smooth[i,j]=beta_hat[1]
    }
  }
  #meanfunction
  mean_function=function(Y_smooth,n,t2){
    Y_mean=rep(0,length(t2))
    for(j in 1:length(t2)){
      Y_mean[j]=sum(Y_smooth[,j])/n
    }
    return(Y_mean=Y_mean)
  }
  Y_mean=mean_function(Y_smooth,n,t2)
  return(list(t2=t2,Y_smooth=Y_smooth,Y_mean=Y_mean))
}
result2=Smooth_function1(t,Y,n,h=0.3,t2=seq(0.2,0.8,length=200))
Y_smooth=result2$Y_smooth
t2=result2$t2
Y_mean=result2$Y_mean
matplot(t2, t(Y_smooth), type='l', lty=1,col=rainbow(nrow(Y_smooth)),
        xlab='t2', ylab='Y_smooth(t)', main='找mean function')
lines(t2,Y_mean,col="black",type='l',lwd=3)



