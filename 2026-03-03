Smooth_function=function(t,Y,n=20,h=0.3){
  Y_smooth=matrix(0,nrow=n,ncol=length(t))
  for(i in 1:length(t)){
    t0=t[i]
    z=(t-t0)/h
    k=ifelse((3/4)*(1-z^2)>=0,(3/4)*(1-z^2),0)
    W=diag(k)
    T1=cbind(1,(t-t0))
    beta_hat=solve(t(T1)%*%W%*%T1)%*%t(T1)%*%W%*%t(Y)
    Y_smooth[,i]=beta_hat[1,]
  }
  return(list(t=t,Y_smooth=Y_smooth))
}
